{
  "name": "nextjs-component-library",
  "version": "1.0.0",
  "author": {
    "name": "Aishwarya B R",
    "email": "aishwarya.b.raghavan@gmail.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "extract-props": "node scripts/extract-props.mjs",
    "build:lib": "pnpm run build:js && pnpm run build:css",
    "build:js": "tsup && node scripts/copy-component-css.mjs",
    "build:css": "tailwindcss -i src/styles/globals.css -o dist/styles/globals.css --minify",
    "prepublishOnly": "pnpm run build:lib",
    "prepare": "pnpm run build:lib"
  },
  "dependencies": {
    "next": "15.2.3",
    "react-icons": "^5.6.0",
    "react-simple-animate": "^3.5.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "description": "Built with Next.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles/globals.css": "./dist/styles/globals.css",
    "./package.json": "./package.json"
  },
  "keywords": [],
  "license": "ISC"
}
