    },
    "./nav-list": {
      "types": "./dist/components/navList/NavList.d.ts",
      "import": "./dist/components/navList/NavList.mjs",
      "require": "./dist/components/navList/NavList.js"
    },
    "./side-menu": {
      "types": "./dist/components/sideMenu/SideMenu.d.ts",
