    },
    "./timeline": {
      "types": "./dist/components/timeline/Timeline.d.ts",
      "import": "./dist/components/timeline/Timeline.mjs",
      "require": "./dist/components/timeline/Timeline.js"
    },
    "./toast": {
      "types": "./dist/components/toast/Toast.d.ts",
      "import": "./dist/components/toast/Toast.mjs",
      "require": "./dist/components/toast/Toast.js"
    },
    "./typography": {
      "types": "./dist/components/typography/Typography.d.ts",
      "import": "./dist/components/typography/Typography.mjs",
      "require": "./dist/components/typography/Typography.js"
    },
    "./center-wrapper": {
      "types": "./dist/components/wrapper/CenterWrapper.d.ts",
      "import": "./dist/components/wrapper/CenterWrapper.mjs",
      "require": "./dist/components/wrapper/CenterWrapper.js"
    },
    "./use-form": {
      "types": "./dist/hooks/useForm.d.ts",
      "import": "./dist/hooks/useForm.mjs",
      "require": "./dist/hooks/useForm.js"
    },
    "./use-scroll": {
      "types": "./dist/hooks/useScroll.d.ts",
