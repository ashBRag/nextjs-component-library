{
  "name": "nextjs-component-library",
  "version": "1.0.0",
  "author": {
    "name": "Aishwarya B R",
    "email": "aishwarya.b.raghavan@gmail.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "extract-props": "node scripts/extract-props.mjs",
    "build:lib": "pnpm run build:js && pnpm run build:css",
    "build:js": "tsup && node scripts/copy-component-css.mjs",
    "build:css": "tailwindcss -i src/styles/globals.css -o dist/styles/globals.css --minify",
    "prepublishOnly": "pnpm run build:lib",
    "prepare": "pnpm run build:lib"
  },
  "dependencies": {
    "next": "15.2.3",
    "react-icons": "^5.6.0",
    "react-simple-animate": "^3.5.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "description": "Built with Next.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./badge": {
      "types": "./dist/components/badge/Badge.d.ts",
      "import": "./dist/components/badge/Badge.mjs",
      "require": "./dist/components/badge/Badge.js"
    },
    "./button": {
      "types": "./dist/components/button/Button.d.ts",
      "import": "./dist/components/button/Button.mjs",
      "require": "./dist/components/button/Button.js"
    },
    "./card": {
      "types": "./dist/components/card/Card.d.ts",
      "import": "./dist/components/card/Card.mjs",
      "require": "./dist/components/card/Card.js"
    },
    "./chip": {
      "types": "./dist/components/chip/Chip.d.ts",
      "import": "./dist/components/chip/Chip.mjs",
      "require": "./dist/components/chip/Chip.js"
    },
    "./dialog": {
      "types": "./dist/components/dialog/Dialog.d.ts",
      "import": "./dist/components/dialog/Dialog.mjs",
      "require": "./dist/components/dialog/Dialog.js"
    },
    "./divider": {
      "types": "./dist/components/divider/Divider.d.ts",
      "import": "./dist/components/divider/Divider.mjs",
      "require": "./dist/components/divider/Divider.js"
    },
    "./drawer": {
      "types": "./dist/components/drawer/Drawer.d.ts",
      "import": "./dist/components/drawer/Drawer.mjs",
      "require": "./dist/components/drawer/Drawer.js"
    },
    "./radio-group": {
      "types": "./dist/components/form/radio-group/RadioGroup.d.ts",
      "import": "./dist/components/form/radio-group/RadioGroup.mjs",
      "require": "./dist/components/form/radio-group/RadioGroup.js"
    },
    "./select": {
      "types": "./dist/components/form/select/Select.d.ts",
      "import": "./dist/components/form/select/Select.mjs",
      "require": "./dist/components/form/select/Select.js"
    },
    "./status-bar": {
      "types": "./dist/components/form/status-bar/StatusBar.d.ts",
