      "require": "./dist/hooks/useScroll.js"
    },
    "./use-theme": {
      "types": "./dist/hooks/useTheme.d.ts",
      "import": "./dist/hooks/useTheme.mjs",
      "require": "./dist/hooks/useTheme.js"
    },
    "./use-toast": {
      "types": "./dist/hooks/useToast.d.ts",
      "import": "./dist/hooks/useToast.mjs",
      "require": "./dist/hooks/useToast.js"
    },
    "./theme-provider": {
      "types": "./dist/providers/ThemeProvider.d.ts",
      "import": "./dist/providers/ThemeProvider.mjs",
      "require": "./dist/providers/ThemeProvider.js"
    },
    "./api": {
      "types": "./dist/lib/api.d.ts",
      "import": "./dist/lib/api.mjs",
      "require": "./dist/lib/api.js"
    },
    "./lib-utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.mjs",
      "require": "./dist/lib/utils.js"
    },
    "./form-validations": {
      "types": "./dist/utils/formValidations.d.ts",
      "import": "./dist/utils/formValidations.mjs",
      "require": "./dist/utils/formValidations.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    },
    "./styles/globals.css": "./dist/styles/globals.css",
    "./package.json": "./package.json"
  },
  "keywords": [],
  "license": "ISC"
}
